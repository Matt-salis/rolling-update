<Window
    x:Class="RollingUpdateManager.Views.AddEditServiceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Configurar Servicio"
    Width="560" SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#252526">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>

        <!-- TextBox con placeholder via Tag + AdornerDecorator trick -->
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#3C3C3C"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#555"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="2">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                <TextBlock Text="{TemplateBinding Tag}"
                                           Foreground="#666" Margin="8,5,0,0"
                                           IsHitTestVisible="False" Focusable="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Text}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Background"   Value="#0078D4"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <!-- Nombre -->
        <Label Content="Nombre del servicio *"/>
        <TextBox x:Name="TxtName" Tag="Ej: API Gateway"/>

        <!-- JAR -->
        <Label Content="Ruta del archivo .jar *"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtJarPath" Tag="C:\apps\myapp.jar"/>
            <Button Grid.Column="1" Content="…" Style="{StaticResource BrowseBtn}"
                    Margin="4,0,0,8" Click="BrowseJar_Click"/>
        </Grid>

        <!-- Config file -->
        <Label Content="Archivo de configuración (.properties / .yml)"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtConfigPath" Tag="C:\apps\application.properties (opcional)"/>
            <Button Grid.Column="1" Content="…" Style="{StaticResource BrowseBtn}"
                    Margin="4,0,0,8" Click="BrowseConfig_Click"/>
        </Grid>

        <!-- Puertos -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Puerto público fijo *"/>
                <TextBox x:Name="TxtPublicPort" Text="8080"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Timeout health-check (seg)"/>
                <TextBox x:Name="TxtTimeout" Text="60"/>
            </StackPanel>
        </Grid>

        <!-- Argumentos JVM -->
        <Label Content="Argumentos JVM adicionales"/>
        <TextBox x:Name="TxtJvmArgs" Tag="-Xmx512m -Xms256m"/>

        <!-- Java executable -->
        <Label Content="Ejecutable Java (vacío = PATH)"/>
        <TextBox x:Name="TxtJavaExe" Text="java"/>

        <!-- Health check path -->
        <Label Content="Endpoint health-check"/>
        <TextBox x:Name="TxtHealthPath" Text="/actuator/health"/>

        <!-- Drain delay -->
        <Label Content="Drain delay tras swap de proxy (ms)"/>
        <TextBox x:Name="TxtDrainDelay" Text="3000"/>

        <!-- Timeouts del proxy -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Timeout proxy &#x2014; headers (seg)"/>
                <TextBox x:Name="TxtProxyTimeout" Text="240" Tag="Ej: 240"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Timeout proxy &#x2014; body/PDF (seg)"/>
                <TextBox x:Name="TxtProxyBodyTimeout" Text="230" Tag="Ej: 230"/>
            </StackPanel>
        </Grid>

        <!-- AutoStart -->
        <CheckBox x:Name="ChkAutoStart" Content="Iniciar automáticamente con la aplicación" IsChecked="True"/>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Click="Cancel_Click"
                    Background="#555" Foreground="White" BorderThickness="0"
                    Padding="16,6" Margin="0,0,8,0" Cursor="Hand"/>
            <Button Content="Guardar" Click="Save_Click"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    Padding="16,6" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
