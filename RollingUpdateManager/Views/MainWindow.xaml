<Window
    x:Class="RollingUpdateManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:RollingUpdateManager.ViewModels"
    xmlns:conv="clr-namespace:RollingUpdateManager.Converters"
    mc:Ignorable="d"
    Title="Rolling Update Manager"
    Icon="/logo.ico"
    Height="700" Width="1100"
    MinHeight="560" MinWidth="860"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E">

    <Window.Resources>
        <conv:StatusToColorConverter      x:Key="StatusToColor"/>
        <conv:StatusToTextConverter       x:Key="StatusToText"/>
        <conv:BoolToVisibilityConverter   x:Key="BoolToVis"/>
        <conv:SlotLabelToColorConverter   x:Key="SlotToColor"/>
        <conv:ZeroToEmptyConverter        x:Key="ZeroToEmpty"/>

        <!-- ── Base template for all flat buttons ─────────────────────── -->
        <ControlTemplate x:Key="FlatBtn" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.80"/></Trigger>
                <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.60"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.30"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- service-card action buttons -->
        <Style x:Key="BtnAct" TargetType="Button">
            <Setter Property="Background"      Value="#2E7D32"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource FlatBtn}"/>
        </Style>
        <Style x:Key="BtnStop"    TargetType="Button" BasedOn="{StaticResource BtnAct}"><Setter Property="Background" Value="#B71C1C"/></Style>
        <Style x:Key="BtnRestart" TargetType="Button" BasedOn="{StaticResource BtnAct}"><Setter Property="Background" Value="#E65100"/></Style>
        <Style x:Key="BtnRdploy" TargetType="Button" BasedOn="{StaticResource BtnAct}">
            <Setter Property="Background" Value="#4527A0"/><Setter Property="Padding" Value="7,3"/>
        </Style>
        <Style x:Key="BtnUpd" TargetType="Button" BasedOn="{StaticResource BtnAct}">
            <Setter Property="Background" Value="#0D47A1"/><Setter Property="Padding" Value="9,3"/>
        </Style>
        <!-- Kill port — subtle red, visible enough to find but not dominant -->
        <Style x:Key="BtnKill" TargetType="Button">
            <Setter Property="Background"      Value="#3A1010"/>
            <Setter Property="Foreground"      Value="#CC5555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="7,3"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource FlatBtn}"/>
        </Style>
        <!-- toolbar buttons -->
        <Style x:Key="BtnTb" TargetType="Button">
            <Setter Property="Foreground"      Value="#BBBBBB"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource FlatBtn}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#3C3C3C"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnTbBlue" TargetType="Button" BasedOn="{StaticResource BtnTb}">
            <Setter Property="Background" Value="#0D47A1"/><Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnTbRed" TargetType="Button" BasedOn="{StaticResource BtnTb}">
            <Setter Property="Background" Value="#7F0000"/><Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnTbAmber" TargetType="Button" BasedOn="{StaticResource BtnTb}">
            <Setter Property="Background" Value="#2A1800"/><Setter Property="Foreground" Value="#FFB74D"/>
        </Style>

        <!-- shared slot-tab ToggleButton -->
        <Style x:Key="SlotTab" TargetType="ToggleButton">
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Foreground"      Value="#777"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Margin"          Value="0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background"  Value="#1E1E1E"/>
                                <Setter Property="Foreground"  Value="White"/>
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2A2A2E"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Opacity" Value="0.35"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>   <!-- Contenido -->
            <RowDefinition Height="28"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  TOOLBAR                                                           -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#2D2D30" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" VerticalAlignment="Stretch">
                <!-- brand -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Image Source="/logo.ico" Width="18" Height="18" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Rolling Update Manager"
                               Foreground="#666" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="7,0,0,0"/>
                </StackPanel>
                <!-- actions — right side -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Stretch" Margin="0,0,4,0">
                    <Button Content="⬆ Manager" Style="{StaticResource BtnTbAmber}"
                            Command="{Binding UpdateManagerCommand}"
                            ToolTip="Actualiza este exe sin detener los servicios JAR"/>
                    <Rectangle Width="1" Fill="#3C3C3C" Margin="4,9"/>
                    <Button Content="▶ All" Style="{StaticResource BtnTbBlue}"
                            Command="{Binding StartAllCommand}"
                            ToolTip="Iniciar todos los servicios detenidos"
                            Margin="0,0,2,0"/>
                    <Button Content="⏹ All" Style="{StaticResource BtnTbRed}"
                            Command="{Binding StopAllCommand}"
                            ToolTip="Detener todos los servicios en ejecución"/>
                    <Rectangle Width="1" Fill="#3C3C3C" Margin="4,9"/>
                    <Button Content="+" Style="{StaticResource BtnTb}"
                            Command="{Binding AddServiceCommand}"    ToolTip="Agregar servicio"/>
                    <Button Content="✎" Style="{StaticResource BtnTb}"
                            Command="{Binding EditServiceCommand}"   ToolTip="Editar servicio seleccionado"/>
                    <Button Content="✕" Style="{StaticResource BtnTb}"
                            Command="{Binding RemoveServiceCommand}" ToolTip="Eliminar servicio seleccionado"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  CONTENIDO PRINCIPAL                                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="260"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Lista de servicios ──────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#2D2D30" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="SERVICIOS"
                               Foreground="#AAAAAA" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="12,0"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Services}"
                             SelectedItem="{Binding SelectedService}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"          Value="0"/>
                                <Setter Property="Margin"           Value="3,2"/>
                                <Setter Property="Background"       Value="Transparent"/>
                                <Setter Property="BorderThickness"  Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#0A3D5F"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#27272B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ServiceItemViewModel}">
                                <Border Padding="10,7" CornerRadius="3">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>  <!-- name + status -->
                                            <RowDefinition/>  <!-- ports + uptime -->
                                            <RowDefinition/>  <!-- actions -->
                                            <RowDefinition/>  <!-- CPU / RAM -->
                                            <RowDefinition/>  <!-- proxy metrics -->
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: name + slot badge  |  status pill -->
                                        <DockPanel Grid.Row="0" LastChildFill="False">
                                            <Border DockPanel.Dock="Right"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                    Padding="5,1" CornerRadius="7" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           Foreground="White" FontSize="10"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#E0E0E0" FontSize="13" FontWeight="SemiBold"/>
                                                <Border Background="{Binding ActiveSlotLabel, Converter={StaticResource SlotToColor}}"
                                                        Margin="7,0,0,0" Padding="4,0" CornerRadius="3" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ActiveSlotLabel}"
                                                               Foreground="White" FontSize="10"/>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- Row 1: port info + uptimes (compact) -->
                                        <TextBlock Grid.Row="1" Margin="0,3,0,0" Foreground="#5A5A5A" FontSize="10">
                                            <Run Text=":"/><Run Text="{Binding PublicPort}" Foreground="#5B9BD5" FontWeight="SemiBold"/>
                                            <Run Text="→"/><Run Text="{Binding ActiveInternalPort, Converter={StaticResource ZeroToEmpty}}"
                                                                  Foreground="#6AAB74" FontWeight="SemiBold"/>
                                            <Run Text="  ⏱"/><Run Text="{Binding Uptime}" Foreground="#717171"/>
                                            <Run Text="  ✓"/><Run Text="{Binding StableUptimeLabel}" Foreground="#5A8A5E"/>
                                        </TextBlock>

                                        <!-- Row 2: action buttons -->
                                        <DockPanel Grid.Row="2" Margin="0,5,0,0" LastChildFill="False">
                                            <!-- kill port far right -->
                                            <Button DockPanel.Dock="Right" Style="{StaticResource BtnKill}"
                                                    Content="⊗ Kill port" Command="{Binding KillPortCommand}"
                                                    ToolTip="Matar proceso que ocupa el puerto público"/>
                                            <!-- primary lifecycle -->
                                            <Button Content="▶" Style="{StaticResource BtnAct}"
                                                    Command="{Binding StartCommand}"    ToolTip="Start"   Margin="0,0,2,0"/>
                                            <Button Content="⏹" Style="{StaticResource BtnStop}"
                                                    Command="{Binding StopCommand}"    ToolTip="Stop"    Margin="0,0,2,0"/>
                                            <Button Content="↺ Restart" Style="{StaticResource BtnRestart}"
                                                    Command="{Binding RestartCommand}"
                                                    ToolTip="Reinicio forzado — detiene y arranca (downtime ~3 s)"
                                                    Margin="0,0,6,0"/>
                                            <!-- deploy actions -->
                                            <Button Content="⬆ Redeploy" Style="{StaticResource BtnRdploy}"
                                                    Command="{Binding RedeployCommand}"
                                                    ToolTip="Redeploy sin downtime — rolling update blue/green con el mismo JAR"
                                                    Margin="0,0,2,0"/>
                                            <Button Content="⬆ Update JAR" Style="{StaticResource BtnUpd}"
                                                    Command="{Binding UpdateJarCommand}"
                                                    ToolTip="Seleccionar nuevo JAR y hacer rolling update sin downtime"/>
                                        </DockPanel>

                                        <!-- Row 3: CPU / RAM del proceso activo -->
                                        <TextBlock Grid.Row="3" Margin="0,4,0,0" Foreground="#4A4A4A" FontSize="10">
                                            <Run Text="CPU "/><Run Text="{Binding CpuPercent}" Foreground="#7A9040" FontWeight="SemiBold"/>
                                            <Run Text="  RAM "/><Run Text="{Binding MemMb}" Foreground="#3A7A8A" FontWeight="SemiBold"/>
                                        </TextBlock>

                                        <!-- Row 4: proxy metrics (requests, latency, errors) -->
                                        <TextBlock Grid.Row="4" Margin="0,2,0,0" Foreground="#444" FontSize="10">
                                            <Run Text="⚡"/><Run Text="{Binding ReqPerSec}" Foreground="#8A7900" FontWeight="SemiBold"/>
                                            <Run Text="r/s  ⏱"/><Run Text="{Binding AvgLatencyMs}" Foreground="#336A8A" FontWeight="SemiBold"/>
                                            <Run Text="ms  ✗"/><Run Text="{Binding ErrorRate}" Foreground="#7A2A2A" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ── Splitter ────────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#2A2A2E" Cursor="SizeWE"/>

            <!-- ── Panel derecho: logs ─────────────────────────────────────── -->
            <Grid Grid.Column="2" Background="#1A1A1A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log header: tabs | service name | clear -->
                <Border Grid.Row="0" Background="#252526" BorderBrush="#2D2D30" BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="False">
                        <!-- slot tabs — left -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Stretch">
                            <ToggleButton x:Name="TabAll"   Tag="{x:Null}" Content="All"
                                          Style="{StaticResource SlotTab}"
                                          IsChecked="True" Click="SlotTabClicked"/>
                            <Rectangle Width="1" Fill="#333" Margin="0,7"/>
                            <ToggleButton x:Name="TabBlue" Tag="Blue"
                                          Style="{StaticResource SlotTab}"
                                          Click="SlotTabClicked"
                                          IsEnabled="{Binding SelectedService.HasBlueInstance, FallbackValue=False}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Blue" VerticalAlignment="Center"/>
                                    <Border Margin="5,0,0,0" Padding="4,0" CornerRadius="3"
                                            Background="#1565C0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedService.LiveSlot}" Value="Blue">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="live" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </ToggleButton>
                            <Rectangle Width="1" Fill="#333" Margin="0,7"/>
                            <ToggleButton x:Name="TabGreen" Tag="Green"
                                          Style="{StaticResource SlotTab}"
                                          Click="SlotTabClicked"
                                          IsEnabled="{Binding SelectedService.HasGreenInstance, FallbackValue=False}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Green" VerticalAlignment="Center"/>
                                    <Border Margin="5,0,0,0" Padding="4,0" CornerRadius="3"
                                            Background="#2E7D32" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedService.LiveSlot}" Value="Green">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="live" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                        <!-- right: service name + clear -->
                        <Button DockPanel.Dock="Right"
                                x:Name="BtnClearLog" Content="Clear"
                                Click="ClearLog_Click" ToolTip="Limpiar log visible"
                                Style="{StaticResource BtnKill}"
                                VerticalAlignment="Stretch" Padding="10,0" FontSize="11"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding SelectedService.Name, FallbackValue=''}"
                                   Foreground="#3A3A3A" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                    </DockPanel>
                </Border>

                <!-- empty state -->
                <TextBlock Grid.Row="1"
                           Text="Selecciona un servicio para ver sus logs"
                           Foreground="#3A3A3A" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding SelectedService, Converter={StaticResource BoolToVis},
                                        ConverterParameter=invert, FallbackValue=Visible}"/>

                <!-- log viewer -->
                <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Background="#1A1A1A"
                              Visibility="{Binding SelectedService, Converter={StaticResource BoolToVis}}">
                    <TextBox x:Name="LogTextBox"
                             Background="#1A1A1A" Foreground="#C0C0C0"
                             FontFamily="Consolas, Courier New" FontSize="12"
                             BorderThickness="0" IsReadOnly="True"
                             IsReadOnlyCaretVisible="False" IsUndoEnabled="False"
                             TextWrapping="NoWrap" AcceptsReturn="True" AcceptsTab="False"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"
                             Padding="8,4"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  STATUS BAR                                                        -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#007ACC">
            <TextBlock Text="{Binding StatusBarText}"
                       Foreground="White" FontSize="11"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Border>
    </Grid>
</Window>
