<Window
    x:Class="RollingUpdateManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:RollingUpdateManager.ViewModels"
    xmlns:conv="clr-namespace:RollingUpdateManager.Converters"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    mc:Ignorable="d"
    Title="Rolling Update Manager"
    Height="700" Width="1100"
    MinHeight="600" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E">

    <Window.Resources>
        <conv:StatusToColorConverter      x:Key="StatusToColor"/>
        <conv:StatusToTextConverter       x:Key="StatusToText"/>
        <conv:BoolToVisibilityConverter   x:Key="BoolToVis"/>
        <conv:SlotLabelToColorConverter   x:Key="SlotToColor"/>
        <conv:ZeroToEmptyConverter        x:Key="ZeroToEmpty"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>   <!-- Contenido -->
            <RowDefinition Height="28"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  TOOLBAR                                                           -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252526">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">

                <Button Content="➕ Agregar"
                        Command="{Binding AddServiceCommand}"
                        Margin="4,0" Padding="12,4"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <Button Content="✏️ Editar"
                        Command="{Binding EditServiceCommand}"
                        Margin="4,0" Padding="12,4"
                        Background="#3C3C3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <Button Content="🗑 Eliminar"
                        Command="{Binding RemoveServiceCommand}"
                        Margin="4,0" Padding="12,4"
                        Background="#3C3C3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <Separator Margin="8,4" Background="#555"/>

                <Button Content="▶ Start All"
                        Command="{Binding StartAllCommand}"
                        Margin="4,0" Padding="12,4"
                        Background="#388E3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <Button Content="⏹ Stop All"
                        Command="{Binding StopAllCommand}"
                        Margin="4,0" Padding="12,4"
                        Background="#C62828" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <TextBlock Text="Rolling Update Manager"
                           Foreground="#AAAAAA" FontSize="13"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  CONTENIDO PRINCIPAL                                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" MinWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Lista de servicios ──────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="SERVICIOS"
                               Foreground="#AAAAAA" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="12,0"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Services}"
                             SelectedItem="{Binding SelectedService}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"       Value="0"/>
                                <Setter Property="Margin"        Value="4,2"/>
                                <Setter Property="Background"    Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#094771"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2D2D30"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ServiceItemViewModel}">
                                <Border Padding="10,8" CornerRadius="4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Nombre + indicador slot -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <Border Background="{Binding ActiveSlotLabel, Converter={StaticResource SlotToColor}}"
                                                    Margin="8,0,0,0" Padding="4,1" CornerRadius="3">
                                                <TextBlock Text="{Binding ActiveSlotLabel}"
                                                           Foreground="White" FontSize="10"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Status pill -->
                                        <Border Grid.Row="0" Grid.Column="1"
                                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                Padding="6,2" CornerRadius="8">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>

                                        <!-- Puertos -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Foreground="#AAAAAA" FontSize="11" Margin="0,3,0,0">
                                            <Run Text="Puerto público:"/>
                                            <Run Text="{Binding PublicPort}" FontWeight="Bold" Foreground="#64B5F6"/>
                                            <Run Text="  →  interno:"/>
                                            <Run Text="{Binding ActiveInternalPort, Converter={StaticResource ZeroToEmpty}}"
                                                 FontWeight="Bold" Foreground="#81C784"/>
                                        </TextBlock>

                                        <!-- Uptime + acciones rápidas -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,6,0,0">
                                            <Button Content="▶" ToolTip="Start"
                                                    Command="{Binding StartCommand}"
                                                    Padding="6,2" Margin="0,0,4,0"
                                                    Background="#388E3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="⏹" ToolTip="Stop"
                                                    Command="{Binding StopCommand}"
                                                    Padding="6,2" Margin="0,0,4,0"
                                                    Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="🔄" ToolTip="Restart"
                                                    Command="{Binding RestartCommand}"
                                                    Padding="6,2" Margin="0,0,4,0"
                                                    Background="#F57C00" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="⬆ Update JAR" ToolTip="Rolling update"
                                                    Command="{Binding UpdateJarCommand}"
                                                    Padding="8,2"
                                                    Background="#0078D4" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{Binding Uptime}"
                                                   Foreground="#888" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,6,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ── Splitter ────────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#3C3C3C"/>

            <!-- ── Panel derecho: logs ─────────────────────────────────────── -->
            <Grid Grid.Column="2" Background="#1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Foreground="#AAAAAA" FontSize="11" FontWeight="Bold">
                            <Run Text="LOGS — "/>
                            <Run Text="{Binding SelectedService.Name, FallbackValue='(selecciona un servicio)'}"
                                 Foreground="White"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Log vacío -->
                <TextBlock Grid.Row="1"
                           Text="Selecciona un servicio para ver sus logs."
                           Foreground="#555" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding SelectedService, Converter={StaticResource BoolToVis},
                                        ConverterParameter=invert, FallbackValue=Visible}"/>

                <!-- Log viewer -->
                <ScrollViewer x:Name="LogScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Background="#1A1A1A"
                              Visibility="{Binding SelectedService, Converter={StaticResource BoolToVis}}">
                    <TextBox x:Name="LogTextBox"
                             Background="#1A1A1A"
                             Foreground="#D4D4D4"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="False"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"
                             Padding="6,4"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  STATUS BAR                                                        -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#007ACC">
            <TextBlock Text="{Binding StatusBarText}"
                       Foreground="White" FontSize="11"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Border>
    </Grid>
</Window>
